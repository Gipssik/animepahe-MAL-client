{
  "name": "animepahoclient",
  "version": "1.0.0",
  "description": "Anime client integrating MAL and AnimePahe",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "axios-cookiejar-support": "^7.0.0",
    "cheerio": "^1.0.0",
    "lucide-react": "^0.344.0",
    "tough-cookie": "^6.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.animepahoclient.app",
    "productName": "AnimePahe Client",
    "files": [
      "out/**/*"
